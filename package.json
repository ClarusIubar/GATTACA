{
  "name": "gattaca",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "live:check": "node scripts/live-check.mjs",
    "live:check:kakao": "node scripts/live-check.mjs --require-kakao",
    "pages:deploy": "node scripts/deploy-pages.mjs --project-name=gattaca --branch main",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run src/App.test.tsx src/test/notification.test.ts src/test/repository.test.ts worker/auth.test.ts worker/kakao-notification.test.ts",
    "test:integration": "vitest run src/test/app-context.test.tsx src/test/app-context-cloudflare.test.tsx worker/worker.test.ts worker/router-crud.test.ts worker/d1-repository.test.ts worker/authorization.test.ts worker/upload.test.ts",
    "test:regression": "vitest run src/App.setup.test.tsx src/test/e2e-flow.test.tsx",
    "test:smoke": "npm run build && npm run live:check:kakao -- --api-url https://gattaca.jamissue.com",
    "test:e2e": "vitest run src/test/e2e-flow.test.tsx",
    "worker:deploy:dry-run": "wrangler deploy --dry-run",
    "worker:deploy": "wrangler deploy"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.96.0"
  }
}
